{
  "name": "asteroids",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "preinstall": "node scripts/ensure-bun.mjs",
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:shaders": "vitest run src/three/__tests__/shaders.spec.ts",
    "build-only": "vite build",
    "copy-spa-fallback": "node scripts/copy-spa-fallback.mjs",
    "deploy": "run-s build copy-spa-fallback deploy:gh-pages",
    "deploy:gh-pages": "node scripts/deploy-gh-pages.mjs",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:oxlint lint:eslint lint:shaders",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache --max-warnings 0",
    "lint:shaders": "node scripts/lint-shaders.mjs",
    "format": "prettier --write --experimental-cli src/",
    "sound:build": "node scripts/optimize-sound.mjs",
    "textures:build": "node scripts/build-textures.mjs",
    "models:shuttle:merge": "node scripts/merge-shuttle-glb.mjs",
    "models:shuttle:inspect": "gltf-transform inspect \"public/models/Space Shuttle (D).glb\"",
    "models:shuttle:prune": "gltf-transform prune \"public/models/shuttle.glb\" \"public/models/shuttle.pruned.glb\"",
    "models:lander:build": "node scripts/optimize-lander-glb.mjs",
    "models:multitool:build": "node scripts/optimize-multitool-glb.mjs",
    "models:asteroids:build": "gltf-transform optimize \"3d/asteroids.glb\" \"public/models/asteroids.glb\" --join false --texture-compress webp --texture-size 2048 --simplify-ratio 0.58 --simplify-error 0.001 --meshopt-level high",
    "models:asteroids:normalize": "node scripts/normalize-asteroid-glbs.mjs",
    "models:bootstrap-heavy-sources": "node scripts/bootstrap-heavy-glb-sources.mjs",
    "models:bed:build": "gltf-transform optimize \"3d/bed.glb\" \"public/models/bed.glb\" --texture-compress webp --texture-size 2048 --simplify-ratio 0.42 --simplify-error 0.001 --meshopt-level high",
    "models:table:build": "gltf-transform optimize \"3d/table.glb\" \"public/models/table.glb\" --texture-compress webp --texture-size 2048 --simplify-ratio 0.55 --simplify-error 0.001 --meshopt-level high",
    "models:city:build": "gltf-transform optimize \"3d/city.glb\" \"public/models/city.glb\" --texture-compress webp --texture-size 2048 --simplify-ratio 0.62 --simplify-error 0.001 --meshopt-level high",
    "models:asteroid:build": "gltf-transform optimize \"3d/asteroid.glb\" \"public/models/asteroid.glb\" --texture-compress webp --texture-size 2048 --simplify-ratio 0.62 --simplify-error 0.0008 --meshopt-level high",
    "models:hubble:build": "gltf-transform optimize \"3d/hubble_rigged.glb\" \"public/models/hubble.glb\" --join false --flatten false --simplify false --texture-compress webp --texture-size 2048 --meshopt-level high",
    "models:voyager:build": "gltf-transform optimize \"3d/voyager_rigged.glb\" \"public/models/voyager.glb\" --join false --flatten false --simplify false --texture-compress webp --texture-size 2048 --meshopt-level high",
    "models:satellite:build": "node scripts/build-satellite-glb.mjs",
    "models:heavy-runtime:build": "run-s models:bootstrap-heavy-sources models:bed:build models:table:build models:city:build models:asteroid:build models:hubble:build models:voyager:build models:satellite:build models:virus:build",
    "models:virus:build": "node scripts/optimize-virus-glb.mjs",
    "models:virus:center": "node scripts/center-virus-glb.mjs"
  },
  "dependencies": {
    "howler": "^2.2.4",
    "pinia": "^3.0.4",
    "postprocessing": "^6.39.1",
    "three": "^0.183.2",
    "three-mesh-bvh": "^0.9.9",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/howler": "^2.2.12",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-oxlint": "~1.57.0",
    "glslx": "^0.3.1",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6",
    "watlas": "^1.0.1"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
